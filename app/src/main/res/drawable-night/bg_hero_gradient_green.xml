<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark surface with faint green tint -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#1A1F23"
                android:endColor="#181E1A"
                android:angle="135" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Green border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/color_hero_green_border" />
            <corners android:radius="20dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
