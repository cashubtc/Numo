<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:elevation="0dp"
        android:background="@color/color_bg_white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="9dp"
            android:background="@drawable/bg_nav_back_button"
            android:src="@drawable/ic_chevron_back"
            android:contentDescription="@string/common_back"
            app:tint="@color/color_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mint_details_title"
            android:textAppearance="@style/Text.Title"
            android:textAlignment="center" />

        <!-- Spacer to balance layout -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <!-- Error Banner -->
    <LinearLayout
        android:id="@+id/error_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="@color/color_error_bg"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_warning"
            app:tint="@color/color_error" />

        <TextView
            android:id="@+id/error_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mint_details_fetch_error"
            android:textSize="14sp"
            android:textColor="@color/color_error" />

        <ImageButton
            android:id="@+id/error_retry_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_refresh"
            app:tint="@color/color_error"
            android:contentDescription="@string/common_retry" />

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/error_banner"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ==================== -->
            <!-- HEADER SECTION (Hero Card) -->
            <!-- ==================== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_gradient_green">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="24dp">

                        <!-- Icon -->
                        <FrameLayout
                            android:id="@+id/icon_container"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_circle"
                            android:backgroundTint="@color/color_bg_tertiary">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/mint_icon"
                                android:layout_width="78dp"
                                android:layout_height="78dp"
                                android:layout_gravity="center"
                                android:scaleType="centerCrop"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                                app:strokeColor="@color/color_bg_white"
                                app:strokeWidth="2dp"
                                android:src="@drawable/ic_bitcoin"
                                android:contentDescription="@string/cd_mint_icon" />

                        </FrameLayout>

                        <!-- Name -->
                        <TextView
                            android:id="@+id/mint_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Mint Name"
                            android:textSize="24sp"
                            android:textColor="@color/color_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:textAlignment="center" />

                        <!-- URL -->
                        <TextView
                            android:id="@+id/mint_url"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="mint.example.com"
                            android:textSize="13sp"
                            android:textColor="@color/color_text_tertiary"
                            android:textAlignment="center" />

                        <!-- Balance Badge -->
                        <TextView
                            android:id="@+id/balance_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="10dp"
                            android:background="@drawable/bg_input_pill"
                            android:text="₿0"
                            android:textSize="18sp"
                            android:textColor="@color/color_text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <!-- Lightning Badge (shown if this is the lightning mint) -->
                        <LinearLayout
                            android:id="@+id/lightning_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:background="@drawable/bg_badge_lightning"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_lightning_bolt"
                                app:tint="@color/color_bitcoin_orange" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mints_lightning_mint"
                                android:textSize="13sp"
                                android:textColor="@color/color_bitcoin_orange"
                                android:fontFamily="sans-serif-medium" />

                        </LinearLayout>

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- ==================== -->
            <!-- DESCRIPTION SECTION -->
            <!-- ==================== -->
            <LinearLayout
                android:id="@+id/description_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.SectionHeader"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="14dp"
                    android:text="@string/mint_details_about" />

                <TextView
                    android:id="@+id/description_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <!-- ==================== -->
            <!-- MOTD SECTION -->
            <!-- ==================== -->
            <LinearLayout
                android:id="@+id/motd_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.SectionHeader"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="14dp"
                    android:text="@string/mint_details_announcement" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/color_bitcoin_orange" />

                    <TextView
                        android:id="@+id/motd_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textColor="@color/color_text_primary"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>

            </LinearLayout>

            <!-- ==================== -->
            <!-- DETAILS SECTION -->
            <!-- ==================== -->
            <LinearLayout
                android:id="@+id/details_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.SectionHeader"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="14dp"
                    android:text="@string/mint_details_details" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- URL Row -->
                    <LinearLayout
                        android:id="@+id/url_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="20dp"
                        android:background="@drawable/bg_row_ripple"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mint_details_url"
                            android:textAppearance="@style/Text.RowTitle" />

                        <TextView
                            android:id="@+id/url_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="200dp"
                            android:textAppearance="@style/Text.RowSubtitle"
                            android:textAlignment="textEnd"
                            android:maxLines="1"
                            android:ellipsize="middle" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_copy"
                            app:tint="@color/color_text_tertiary" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:id="@+id/url_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:background="@color/color_divider" />

                    <!-- Software Row -->
                    <LinearLayout
                        android:id="@+id/software_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="20dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mint_details_software"
                            android:textAppearance="@style/Text.RowTitle" />

                        <TextView
                            android:id="@+id/software_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/Text.RowSubtitle"
                            android:textAlignment="textEnd" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:id="@+id/software_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="20dp"
                        android:background="@color/color_divider"
                        android:visibility="gone" />

                    <!-- Version Row -->
                    <LinearLayout
                        android:id="@+id/version_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="20dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/mint_details_version"
                            android:textAppearance="@style/Text.RowTitle" />

                        <TextView
                            android:id="@+id/version_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/Text.RowSubtitle"
                            android:textAlignment="textEnd" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ==================== -->
            <!-- CONTACT SECTION -->
            <!-- ==================== -->
            <LinearLayout
                android:id="@+id/contact_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.SectionHeader"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="14dp"
                    android:text="@string/mint_details_contact" />

                <LinearLayout
                    android:id="@+id/contact_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- ==================== -->
            <!-- ACTIONS SECTION -->
            <!-- ==================== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Text.SectionHeader"
                android:paddingHorizontal="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="14dp"
                android:text="@string/mint_details_actions" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Set as Lightning Mint Button -->
                <LinearLayout
                    android:id="@+id/set_lightning_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_row_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_lightning_bolt"
                        app:tint="@color/color_icon_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Text.RowTitle"
                        android:text="@string/mints_set_as_lightning" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:id="@+id/action_divider_1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="58dp"
                    android:background="@color/color_divider" />

                <!-- Copy URL Button -->
                <LinearLayout
                    android:id="@+id/copy_url_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_row_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/color_icon_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Text.RowTitle"
                        android:text="@string/mint_details_copy_url" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="58dp"
                    android:background="@color/color_divider" />

                <!-- Delete Button -->
                <LinearLayout
                    android:id="@+id/delete_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/bg_row_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_trash"
                        app:tint="@color/color_error" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Text.RowTitle"
                        android:text="@string/mint_details_delete"
                        android:textColor="@color/color_error" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
