<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_s"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <FrameLayout
        android:id="@+id/hero_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_gradient_dark"
        android:clipChildren="false">

        <!-- Decorative background lightning bolt with fade -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="-30dp"
            android:layout_marginBottom="-30dp">

            <ImageView
                android:id="@+id/hero_bolt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.08"
                android:importantForAccessibility="no"
                android:rotation="-15"
                android:src="@drawable/ic_lightning_bolt"
                app:tint="@color/numo_fluorescent_green" />

        </FrameLayout>

        <!-- Content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/margin_screen_horizontal">

            <!-- "DEFAULT MINT" label -->
            <TextView
                android:id="@+id/hero_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Text.SectionHeader"
                android:text="@string/onboarding_mints_hero_label"
                android:textColor="@color/numo_fluorescent_green"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Mint Identity Row -->
            <LinearLayout
                android:id="@+id/hero_mint_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/hero_label">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="@dimen/button_height">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/hero_mint_icon"
            android:importantForAccessibility="no"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop" />

                    <com.electricdreams.numo.ui.animation.GradientRingView
                        android:id="@+id/hero_gradient_ring"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_m"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/hero_mint_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        style="@style/Text.RowTitle"
                        android:textColor="@color/color_text_on_dark"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/hero_mint_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/Text.Caption"
                        android:text="@string/onboarding_mints_hero_subtitle"
                        android:textColor="@color/color_onboarding_text_subtle" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/hero_divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_l"
                android:background="@drawable/bg_divider_fade"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/hero_mint_row" />

            <!-- Helper text -->
            <TextView
                android:id="@+id/hero_helper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:textAppearance="@style/Text.Caption"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/onboarding_mints_hero_helper"
                android:textColor="@color/color_onboarding_text_muted"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/hero_divider" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
