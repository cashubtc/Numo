<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:background="@color/color_bg_white"
        android:paddingHorizontal="@dimen/space_l"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/icon_size_large"
            android:minHeight="@dimen/icon_size_large"
            android:padding="@dimen/space_m"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_back"
            android:src="@drawable/ic_chevron_back"
            app:tint="@color/color_text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pin_reset_title"
            android:textAppearance="@style/Text.Title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <!-- Warning Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/margin_screen_horizontal"
                android:background="@drawable/bg_warning_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:importantForAccessibility="no"
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:layout_marginEnd="@dimen/space_m"
                        android:src="@drawable/ic_warning"
                        app:tint="@color/color_warning" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pin_reset_warning_title"
                        android:textAppearance="@style/Text.RowTitle" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    android:text="@string/pin_reset_warning_message"
                    android:textAppearance="@style/Text.Body"
                    android:textColor="@color/color_text_secondary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Seed Phrase Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2xl"
                android:layout_marginBottom="@dimen/space_l"
                android:text="@string/pin_reset_recovery_phrase"
                android:textAppearance="@style/Text.BodyBold"
                android:textColor="@color/color_text_secondary" />

            <!-- Seed Input Grid -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/seed_input_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:rowCount="6"
                app:useDefaultMargins="false" />

            <!-- Paste Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/paste_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_l"
                android:stateListAnimator="@null"
                android:text="@string/pin_reset_paste_clipboard"
                android:textAppearance="@style/Text.Chip"
                app:elevation="0dp"
                app:icon="@drawable/ic_content_copy"
                app:iconTint="@color/color_text_primary"
                app:iconPadding="@dimen/space_s"
                app:strokeColor="@color/color_divider"
                app:cornerRadius="22dp" />

            <!-- Validation Status -->
            <LinearLayout
                android:id="@+id/validation_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_l"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:importantForAccessibility="no"
                    android:id="@+id/validation_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="@dimen/space_s" />

                <TextView
                    android:id="@+id/validation_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Chip" />

            </LinearLayout>

            <!-- Reset Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_button"
                style="@style/Widget.Numo.Button.Dialog.Destructive"
                android:layout_width="match_parent"
                android:layout_height="@dimen/top_bar_height"
                android:layout_marginTop="@dimen/space_xl"
                android:text="@string/pin_reset_button"
                android:enabled="false"
                android:alpha="0.5" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
