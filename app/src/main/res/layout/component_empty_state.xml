<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingVertical="40dp"
    android:paddingHorizontal="24dp">

    <!-- Rounded square icon container -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_empty_state_icon">

        <ImageView
            android:id="@+id/empty_state_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            app:tint="@color/color_text_tertiary" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/empty_state_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:letterSpacing="-0.012"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <!-- Description -->
    <TextView
        android:id="@+id/empty_state_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:maxWidth="260dp"
        android:textColor="@color/color_text_tertiary"
        android:textSize="13sp" />

    <!-- Optional action button (hidden by default) -->
    <TextView
        android:id="@+id/empty_state_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_empty_state_action_button"
        android:drawablePadding="6dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:textColor="@color/color_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
