<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Close Button (top-left) -->
    <ImageButton
        android:id="@+id/close_button"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:layout_marginStart="@dimen/space_s"
        android:layout_marginTop="@dimen/space_s"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/common_close"
        android:padding="@dimen/space_m"
        android:src="@drawable/ic_close"
        app:tint="@color/color_text_secondary" />

    <!-- Icon (optional, hidden by default) -->
    <ImageView
        android:id="@+id/dialog_icon"
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:layout_marginStart="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_xs"
        android:visibility="gone"
        app:tint="@color/color_text_tertiary"
        tools:src="@drawable/ic_warning"
        tools:visibility="visible" />

    <!-- Title -->
    <TextView
        android:id="@+id/dialog_title"
        style="@style/Text.DialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_m"
        android:text="Confirm"
        tools:text="Set as Default?" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/dialog_subtitle"
        style="@style/Text.DialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_xs"
        android:visibility="gone"
        tools:text="This action can be changed later"
        tools:visibility="visible" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height_thick"
        android:layout_marginTop="@dimen/space_l"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:background="@color/color_divider" />

    <!-- Message / Description -->
    <TextView
        android:id="@+id/dialog_message"
        style="@style/Text.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_xl"
        android:text="Are you sure you want to proceed?"
        android:lineSpacingMultiplier="1.4"
        tools:text="Make &quot;Minibits mint&quot; your default mint?" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_screen_horizontal"
        android:paddingBottom="@dimen/space_xl">

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancel_button"
            style="@style/Widget.Numo.Button.Dialog.Cancel"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/space_s"
            android:text="@string/common_cancel" />

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirm_button"
            style="@style/Widget.Numo.Button.Dialog.Confirm"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_s"
            android:text="@string/common_confirm" />

    </LinearLayout>

</LinearLayout>
