<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Lightning Invoice Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/withdraw_invoice_card_title"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <!-- Input Field -->
    <EditText
        android:id="@+id/invoice_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_input_pill"
        android:fontFamily="sans-serif"
        android:hint="@string/withdraw_invoice_placeholder"
        android:inputType="textMultiLine"
        android:maxLines="4"
        android:minHeight="80dp"
        android:padding="14dp"
        android:gravity="top"
        android:textColor="@color/color_text_primary"
        android:textColorHint="@color/color_text_tertiary"
        android:textSize="14sp" />

    <!-- Helper Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.7"
        android:text="@string/withdraw_invoice_helper"
        android:textColor="@color/color_text_secondary"
        android:textSize="13sp" />

    <!-- Continue Button -->
    <Button
        android:id="@+id/continue_button"
        style="@style/Widget.Button.Primary.Green"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:enabled="false"
        android:text="@string/withdraw_continue_button"
        android:textAllCaps="false"
        android:textSize="17sp" />

    <!-- Scan Invoice Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/scan_button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/withdraw_scan_invoice_button"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:textColor="@color/color_text_primary"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="@color/color_bg_white"
        app:strokeColor="@color/color_chip_border"
        app:strokeWidth="1dp"
        app:cornerRadius="26dp"
        app:icon="@drawable/ic_qr_scan"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/color_text_primary"
        app:rippleColor="@color/color_ripple" />

</LinearLayout>
