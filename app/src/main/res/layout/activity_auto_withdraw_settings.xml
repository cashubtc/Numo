<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/auto_withdraw_hero_title"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- ==================== -->
            <!-- MAIN TOGGLE ROW -->
            <!-- ==================== -->
                <LinearLayout
                    android:id="@+id/enable_toggle_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/row_padding_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_withdraw_enable_title"
                            android:textAppearance="@style/Text.RowTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/auto_withdraw_enable_subtitle"
                            android:textAppearance="@style/Text.RowSubtitle" />

                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/enable_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/selector_switch_thumb"
                        app:trackTint="@color/selector_switch_track" />

                </LinearLayout>

                <!-- ==================== -->
                <!-- DESTINATION SECTION -->
                <!-- ==================== -->
                <TextView
                    style="@style/Text.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:paddingTop="@dimen/section_gap"
                    android:paddingBottom="@dimen/row_padding_vertical"
                    android:text="@string/auto_withdraw_section_destination" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                    app:cardBackgroundColor="@color/color_bg_white"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/margin_screen_horizontal">

                        <!-- Lightning Address Label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/space_m"
                            android:text="@string/auto_withdraw_lightning_address_label"
                            style="@style/Text.RowTitle" />

                        <!-- Input Field -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Numo.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/lightning_address_input"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/settings_item_height"
                                android:fontFamily="sans-serif"
                                android:hint="@string/auto_withdraw_lightning_address_hint"
                                android:inputType="textEmailAddress"
                                android:textAppearance="@style/Text.Body"
                                android:textColor="@color/color_text_primary"
                                android:textColorHint="@color/color_text_tertiary" />

                        </com.google.android.material.textfield.TextInputLayout>
                        
                        <!-- Validation Label -->
                        <TextView
                            android:id="@+id/lightning_address_validation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_s"
                            android:textAppearance="@style/Text.Helper"
                            android:visibility="gone"
                            tools:text="@string/auto_withdraw_lightning_address_valid" />

                        <!-- Helper Text -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_s"
                            android:alpha="0.7"
                            android:text="@string/auto_withdraw_lightning_address_helper"
                            android:textAppearance="@style/Text.Helper" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ==================== -->
                <!-- AUTO-WITHDRAW CONFIG (hidden when toggle off) -->
                <!-- ==================== -->
                <LinearLayout
                    android:id="@+id/auto_withdraw_config_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                <!-- ==================== -->
                <!-- TRIGGER SETTINGS -->
                <!-- ==================== -->
                <TextView
                    style="@style/Text.SectionHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:paddingTop="@dimen/section_gap"
                    android:paddingBottom="@dimen/row_padding_vertical"
                    android:text="@string/auto_withdraw_section_trigger" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                    app:cardBackgroundColor="@color/color_bg_white"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:divider="@drawable/bg_divider_inset"
                        android:showDividers="middle">

                        <!-- Threshold Row (whole row opens the edit sheet) -->
                        <LinearLayout
                            android:id="@+id/threshold_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_row_ripple"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="@dimen/margin_screen_horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textAppearance="@style/Text.RowTitle"
                                        android:text="@string/auto_withdraw_threshold_title" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:text="@string/auto_withdraw_threshold_subtitle"
                                        android:textAppearance="@style/Text.RowSubtitle"
                                        android:textColor="@color/color_text_secondary" />

                                </LinearLayout>

                                <!-- Amount Display with ₿ symbol -->
                                <TextView
                                    android:id="@+id/threshold_display"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_pill_badge"
                                    android:fontFamily="sans-serif-medium"
                                    android:paddingHorizontal="@dimen/space_l"
                                    android:paddingVertical="@dimen/space_m"
                                    android:text="₿50,000"
                                    android:textAppearance="@style/Text.RowTitle" />

                                <ImageView
                                    android:importantForAccessibility="no"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginStart="@dimen/space_s"
                                    android:src="@drawable/ic_chevron_forward"
                                    app:tint="@color/color_text_tertiary" />

                        </LinearLayout>

                        <!-- Percentage Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/margin_screen_horizontal">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textAppearance="@style/Text.RowTitle"
                                        android:text="@string/auto_withdraw_percentage_title" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp"
                                        android:text="@string/auto_withdraw_percentage_subtitle"
                                        android:textAppearance="@style/Text.RowSubtitle"
                                        android:textColor="@color/color_text_secondary" />

                                </LinearLayout>

                                <!-- Percentage Badge -->
                                <TextView
                                    android:id="@+id/percentage_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_pill_badge"
                                    android:fontFamily="sans-serif-medium"
                                    android:minWidth="64dp"
                                    android:paddingHorizontal="@dimen/space_l"
                                    android:paddingVertical="@dimen/space_m"
                                    android:text="95%"
                                    android:textAlignment="center"
                                    android:textAppearance="@style/Text.RowTitle" />

                            </LinearLayout>

                            <!-- Slider -->
                            <com.google.android.material.slider.Slider
                                android:id="@+id/percentage_slider"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_l"
                                android:stepSize="1"
                                android:valueFrom="50"
                                android:valueTo="98"
                                app:haloColor="@color/color_primary"
                                app:haloRadius="24dp"
                                app:thumbColor="@color/color_primary"
                                app:thumbRadius="12dp"
                                app:tickVisible="false"
                                app:trackColorActive="@color/color_primary"
                                app:trackColorInactive="@color/color_bg_tertiary"
                                app:trackHeight="6dp" />

                            <!-- Range Labels -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/auto_withdraw_percentage_min"
                                    android:textAppearance="@style/Text.Caption" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_withdraw_percentage_max"
                                    android:textAppearance="@style/Text.Caption" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
