<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp">

    <ImageView
        android:id="@+id/quick_glyph"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_quick_charge"
        app:tint="@color/color_text_tertiary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tx_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp"
        android:text="@string/insights_quick_charge"
        app:layout_constraintStart_toEndOf="@id/quick_glyph"
        app:layout_constraintEnd_toStartOf="@id/tx_total"
        app:layout_constraintTop_toTopOf="@id/quick_glyph" />

    <TextView
        android:id="@+id/tx_meta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:fontFamily="sans-serif"
        android:textColor="@color/color_text_tertiary"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/quick_glyph"
        app:layout_constraintEnd_toStartOf="@id/tx_total"
        app:layout_constraintTop_toBottomOf="@id/tx_title"
        tools:text="Sat · 13:11" />

    <TextView
        android:id="@+id/tx_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="₿0.02M" />

</androidx.constraintlayout.widget.ConstraintLayout>
