<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Close Button (top-left) -->
    <ImageButton
        android:id="@+id/close_button"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:layout_marginStart="@dimen/space_s"
        android:layout_marginTop="@dimen/space_s"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/common_close"
        android:padding="@dimen/space_m"
        android:src="@drawable/ic_close"
        app:tint="@color/color_text_secondary" />

    <!-- Title -->
    <TextView
        android:id="@+id/dialog_title"
        style="@style/Text.DialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_xs"
        android:text="Enter Value"
        tools:text="Edit Threshold" />

    <!-- Description (optional) -->
    <TextView
        android:id="@+id/dialog_description"
        style="@style/Text.DialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_xs"
        android:text="Enter a value below"
        android:lineSpacingMultiplier="1.3"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="Auto-withdraw triggers when balance exceeds this." />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/space_l"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:background="@color/color_divider" />

    <!-- Content Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/margin_screen_horizontal"
        android:paddingTop="@dimen/margin_screen_horizontal">

        <!-- Input Field Container -->
        <LinearLayout
            android:id="@+id/input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input_field_rounded"
            android:padding="@dimen/space_xs">

            <!-- Optional Prefix -->
            <TextView
                android:id="@+id/input_prefix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#8383;"
                android:textSize="18sp"
                android:textColor="@color/color_text_primary"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="@dimen/space_l"
                android:paddingEnd="@dimen/space_xs"
                android:visibility="gone"
                tools:visibility="visible" />

            <EditText
                android:id="@+id/dialog_input"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:background="@null"
                android:paddingHorizontal="@dimen/space_l"
                android:hint="Enter value"
                android:textSize="16sp"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_tertiary"
                android:fontFamily="sans-serif"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionDone"
                tools:text="50000" />

            <!-- Optional Scan Button -->
            <ImageButton
                android:id="@+id/input_scan_button"
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_qr_code"
                android:padding="@dimen/space_m"
                app:tint="@color/color_text_secondary"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Optional Suffix -->
            <TextView
                android:id="@+id/input_suffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textSize="18sp"
                android:textColor="@color/color_text_primary"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="@dimen/space_xs"
                android:paddingEnd="@dimen/space_l"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Helper Text (optional) -->
        <TextView
            android:id="@+id/dialog_helper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_s"
            android:layout_marginHorizontal="@dimen/space_xs"
            android:text="Min: 1,000 - Max: 1,000,000"
            android:textSize="13sp"
            android:textColor="@color/color_text_tertiary"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/save_button"
        style="@style/Widget.Numo.Button.Dialog.Confirm"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
        android:layout_marginTop="@dimen/margin_screen_horizontal"
        android:layout_marginBottom="@dimen/space_xl"
        android:text="@string/common_save" />

</LinearLayout>
