<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:background="@color/color_bg_white"
        android:paddingHorizontal="@dimen/space_l"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="@dimen/icon_size_large"
            android:layout_height="@dimen/icon_size_large"
            android:padding="@dimen/space_m"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/common_back"
            android:src="@drawable/ic_chevron_back"
            app:tint="@color/color_text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_currency_title"
            android:textAppearance="@style/Text.Title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:id="@+id/currency_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Section Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/currency_settings_section_preferred_currency"
                android:textAppearance="@style/Text.SectionHeader" />

            <!-- Currency Radio Group -->
            <RadioGroup
                android:id="@+id/currency_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/radio_usd"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_usd"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_eur"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_eur"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_gbp"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_gbp"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_jpy"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_jpy"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_dkk"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_dkk"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_sek"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_sek"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_nok"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_nok"
                    android:textAppearance="@style/Text.RowTitle" />

                <RadioButton
                    android:id="@+id/radio_krw"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/settings_item_height"
                    android:background="?attr/selectableItemBackground"
                    android:button="@null"
                    android:drawableEnd="@drawable/selector_radio_custom"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/margin_screen_horizontal"
                    android:text="@string/currency_settings_option_krw"
                    android:textAppearance="@style/Text.RowTitle" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
