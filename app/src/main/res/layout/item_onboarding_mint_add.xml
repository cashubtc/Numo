<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/space_xs"
    android:paddingBottom="@dimen/space_s">

    <TextView
        android:id="@+id/add_mint_text"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:background="@drawable/bg_mint_add_button"
        android:gravity="center"
        android:text="@string/onboarding_mints_add_new_button"
        android:textAppearance="@style/Text.BodyBold"
        android:textColor="@color/color_onboarding_text_subtle" />

</FrameLayout>
