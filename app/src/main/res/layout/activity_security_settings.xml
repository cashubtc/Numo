<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white">

    <!-- Top App Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/settings_security_title"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:id="@+id/security_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- ==================== -->
            <!-- WALLET BACKUP SECTION -->
            <!-- ==================== -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/space_l"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/security_settings_section_backup"
                android:textAppearance="@style/Text.SectionHeader" />

            <!-- Security Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                android:layout_marginBottom="@dimen/space_s"
                android:padding="@dimen/margin_screen_horizontal"
                android:background="@drawable/bg_warning_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:importantForAccessibility="no"
                        android:layout_width="@dimen/icon_size_small"
                        android:layout_height="@dimen/icon_size_small"
                        android:layout_marginEnd="@dimen/space_m"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/color_warning" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_card_title"
                        android:textAppearance="@style/Text.RowTitle" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    android:text="@string/security_settings_card_body"
                    android:textAppearance="@style/Text.Body"
                    android:textColor="@color/color_text_secondary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Backup Mnemonic Item -->
            <LinearLayout
                android:id="@+id/backup_mnemonic_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_row_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/row_icon_gap"
                    android:src="@drawable/ic_key"
                    app:tint="@color/color_icon_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_backup_mnemonic_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_backup_mnemonic_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_text_tertiary" />
            </LinearLayout>

            <!-- ===================== -->
            <!-- PIN PROTECTION SECTION -->
            <!-- ===================== -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/section_gap"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/security_settings_section_pin_protection"
                android:textAppearance="@style/Text.SectionHeader" />

            <!-- PIN Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                android:layout_marginBottom="@dimen/space_s"
                android:padding="@dimen/space_l"
                android:background="@drawable/bg_pin_info_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:importantForAccessibility="no"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="@dimen/space_m"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/color_icon_security_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_pin_info_title"
                        android:textAppearance="@style/Text.Chip"
                        android:textColor="@color/color_success_green" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    android:text="@string/security_settings_pin_info_body"
                    android:textAppearance="@style/Text.Caption"
                    android:textColor="@color/color_text_secondary"
                    android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <!-- Set PIN Item -->
            <LinearLayout
                android:id="@+id/setup_pin_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_row_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/row_icon_gap"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/color_icon_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/pin_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_setup_pin_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:id="@+id/pin_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_setup_pin_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_text_tertiary" />
            </LinearLayout>

            <!-- Change PIN Item (shown when PIN is set) -->
            <LinearLayout
                android:id="@+id/change_pin_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_row_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:visibility="gone">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/row_icon_gap"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/color_icon_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_change_pin_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_change_pin_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_text_tertiary" />
            </LinearLayout>

            <!-- Remove PIN Item (shown when PIN is set) -->
            <LinearLayout
                android:id="@+id/remove_pin_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_row_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:visibility="gone">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/row_icon_gap"
                    android:src="@drawable/ic_close"
                    app:tint="@color/color_warning_red" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_remove_pin_title"
                        android:textAppearance="@style/Text.RowTitle"
                        android:textColor="@color/color_warning_red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_remove_pin_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_text_tertiary" />
            </LinearLayout>

            <!-- ======================== -->
            <!-- WALLET RECOVERY SECTION -->
            <!-- ======================== -->

            <!-- Wallet Recovery Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/section_gap"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/security_settings_section_recovery"
                android:textAppearance="@style/Text.SectionHeader" />

            <!-- Restore Wallet Item -->
            <LinearLayout
                android:id="@+id/restore_wallet_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_row_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/row_padding_vertical"
                android:paddingHorizontal="@dimen/margin_screen_horizontal">

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_marginEnd="@dimen/row_icon_gap"
                    android:src="@drawable/ic_restore"
                    app:tint="@color/color_icon_secondary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_restore_wallet_title"
                        android:textAppearance="@style/Text.RowTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security_settings_restore_wallet_subtitle"
                        android:textAppearance="@style/Text.RowSubtitle"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:importantForAccessibility="no"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_forward"
                    app:tint="@color/color_text_tertiary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
