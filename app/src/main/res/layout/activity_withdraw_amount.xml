<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white"
    tools:context=".feature.withdraw.WithdrawAmountActivity">

    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/withdraw_amount_title"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Destination context, e.g. "To you@wallet.com" -->
    <TextView
        android:id="@+id/destination_text"
        style="@style/Text.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        tools:text="To you@wallet.com" />

    <!-- Amount Display -->
    <TextView
        android:id="@+id/amount_display"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_xl"
        android:layout_marginEnd="@dimen/space_xl"
        android:gravity="center"
        android:textColor="@color/color_text_primary"
        android:textSize="64sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:singleLine="true"
        android:ellipsize="none"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="24sp"
        android:autoSizeMaxTextSize="64sp"
        android:autoSizeStepGranularity="2sp"
        app:layout_constraintBottom_toTopOf="@+id/secondary_amount_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/destination_text"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="21,000 ₿" />

    <!-- Secondary Amount Display with Swap Icon -->
    <LinearLayout
        android:id="@+id/secondary_amount_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_m"
        android:paddingVertical="@dimen/space_s"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintBottom_toTopOf="@+id/max_chip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/amount_display">

        <TextView
            android:id="@+id/secondary_amount_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_text_secondary"
            android:textSize="22sp"
            android:textStyle="normal"
            tools:text="≈ $12.40" />

        <ImageButton
            android:id="@+id/currency_switch_button"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="@dimen/space_xs"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:contentDescription="@string/pos_currency_switch_content_description"
            android:focusable="false"
            android:rotation="90"
            android:src="@drawable/ic_switch_currency"
            app:tint="@color/color_text_secondary" />
    </LinearLayout>

    <!-- MAX chip: fills balance minus fee buffer -->
    <TextView
        android:id="@+id/max_chip"
        style="@style/Text.Chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_m"
        android:background="@drawable/bg_pill_badge"
        android:paddingHorizontal="@dimen/space_l"
        android:paddingVertical="@dimen/space_s"
        android:textColor="@color/color_text_secondary"
        app:layout_constraintBottom_toTopOf="@+id/limits_helper"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="MAX 20,580 ₿" />

    <!-- Min/max limits or inline error -->
    <TextView
        android:id="@+id/limits_helper"
        style="@style/Text.Helper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_s"
        android:layout_marginBottom="@dimen/space_m"
        android:gravity="center"
        android:minHeight="18dp"
        app:layout_constraintBottom_toTopOf="@+id/keypad"
        tools:text="Min 10 ₿ • Max 20,580 ₿" />

    <!-- Keypad with fixed height -->
    <GridLayout
        android:id="@+id/keypad"
        android:layout_width="0dp"
        android:layout_height="360dp"
        android:layout_marginHorizontal="@dimen/space_2xl"
        android:layout_marginBottom="@dimen/space_l"
        android:alignmentMode="alignBounds"
        android:columnCount="3"
        android:rowCount="4"
        android:useDefaultMargins="false"
        app:layout_constraintBottom_toTopOf="@+id/continue_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Continue button -->
    <Button
        android:id="@+id/continue_button"
        style="@style/Widget.Button.Primary.Green"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:layout_marginBottom="@dimen/space_xl"
        android:text="@string/withdraw_lightning_button_continue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Loading spinner overlay for continue button -->
    <ProgressBar
        android:id="@+id/continue_button_spinner"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:indeterminateTint="@color/color_bg_white"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/continue_button"
        app:layout_constraintEnd_toEndOf="@id/continue_button"
        app:layout_constraintStart_toStartOf="@id/continue_button"
        app:layout_constraintTop_toTopOf="@id/continue_button" />

</androidx.constraintlayout.widget.ConstraintLayout>
