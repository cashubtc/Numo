<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_card_elevated"
    android:elevation="2dp"
    android:padding="12dp"
    android:id="@+id/main_content">

    <androidx.cardview.widget.CardView
        android:id="@+id/image_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/color_bg_secondary"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/item_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/item_selection_image_description"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/item_image_placeholder"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:contentDescription="@string/item_selection_image_placeholder"
            android:src="@drawable/ic_image_placeholder"
            app:tint="@color/color_icon_tertiary" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:minLines="2"
        android:gravity="center"
        android:textColor="@color/color_text_primary"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/image_container"
        tools:text="Classic T-Shirt" />

    <TextView
        android:id="@+id/item_variation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:gravity="center"
        android:textColor="@color/color_text_tertiary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/item_name"
        tools:text="Medium"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/item_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/color_text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/item_variation"
        tools:text="$24.99" />

    <TextView
        android:id="@+id/item_quantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textColor="@color/color_text_tertiary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/item_price"
        tools:text="12 in stock" />

    <!-- Quantity Controls -->
    <LinearLayout
        android:id="@+id/quantity_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/item_quantity"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/decrease_quantity_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:background="@drawable/bg_quantity_button"
            android:src="@drawable/ic_minus"
            app:tint="@color/color_text_primary"
            android:scaleType="fitCenter"
            android:contentDescription="@string/item_selection_decrease_quantity" />

        <TextView
            android:id="@+id/basket_quantity"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/color_text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium" />

        <ImageButton
            android:id="@+id/increase_quantity_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:background="@drawable/bg_quantity_button"
            android:src="@drawable/ic_plus"
            app:tint="@color/color_text_primary"
            android:scaleType="fitCenter"
            android:contentDescription="@string/item_selection_increase_quantity" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/variation_input_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/quantity_controls">

        <EditText
            android:id="@+id/variation_input"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_variation_input"
            android:hint="@string/item_selection_variation_hint"
            android:imeOptions="actionDone"
            android:inputType="text|textCapSentences"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_tertiary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/add_variation_button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/item_selection_add_variation"
            android:textColor="@color/color_bg_white"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_add_variation_button" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>