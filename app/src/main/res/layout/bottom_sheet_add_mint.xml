<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingBottom="32dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_bottom_sheet_handle" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="24dp"
            android:text="@string/onboarding_add_mint_sheet_title"
            android:textSize="20sp"
            android:textColor="@color/color_text_primary"
            android:fontFamily="sans-serif-medium" />

        <!-- URL Input -->
        <EditText
            android:id="@+id/mint_url_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="24dp"
            android:hint="@string/onboarding_add_mint_url_hint"
            android:textSize="15sp"
            android:textColor="@color/color_text_primary"
            android:textColorHint="@color/color_text_tertiary"
            android:background="@drawable/bg_seed_input"
            android:paddingHorizontal="16dp"
            android:inputType="textUri"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:importantForAutofill="no" />

        <!-- Add Button / Loading Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_mint_button"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/onboarding_add_mint_button"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:enabled="false"
                android:alpha="0.5"
                app:cornerRadius="26dp"
                app:backgroundTint="#000000" />

            <LinearLayout
                android:id="@+id/add_mint_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/color_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/onboarding_add_mint_loading"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary" />

            </LinearLayout>

        </FrameLayout>

        <!-- Divider with "or" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/color_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="@string/onboarding_add_mint_or"
                android:textSize="13sp"
                android:textColor="@color/color_text_tertiary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/color_divider" />

        </LinearLayout>

        <!-- Scan QR Code Row -->
        <LinearLayout
            android:id="@+id/scan_qr_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_mint_item"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_qr_scan"
                app:tint="@color/color_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="@string/onboarding_add_mint_scan_qr"
                android:textSize="16sp"
                android:textColor="@color/color_text_primary"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/color_text_tertiary" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
