<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_dark"
        android:paddingBottom="32dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:background="#26FFFFFF" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="24dp"
            android:text="@string/onboarding_add_mint_sheet_title"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium" />

        <!-- URL Input -->
        <EditText
            android:id="@+id/mint_url_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="24dp"
            android:hint="@string/onboarding_add_mint_url_hint"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#4DFFFFFF"
            android:background="@drawable/bg_seed_input_dark"
            android:paddingHorizontal="16dp"
            android:inputType="textUri"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:importantForAutofill="no" />

        <!-- Add Button / Loading Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_mint_button"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/onboarding_add_mint_button"
                android:textColor="@color/button_text_onboarding"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:background="@drawable/bg_button_white"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                android:enabled="false" />

            <LinearLayout
                android:id="@+id/add_mint_loading"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/numo_fluorescent_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/onboarding_add_mint_loading"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

        </FrameLayout>

        <!-- Scan QR Code Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/scan_qr_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/onboarding_add_mint_scan_qr"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            app:elevation="0dp"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="#26FFFFFF"
            app:strokeWidth="1dp"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_qr_scan"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF"
            app:rippleColor="#1AFFFFFF" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
