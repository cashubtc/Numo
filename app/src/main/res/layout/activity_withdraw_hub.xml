<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_white"
    tools:context=".feature.withdraw.WithdrawHubActivity">

    <!-- Top Bar -->
    <com.electricdreams.numo.ui.components.NumoTopBar
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        app:topBarTitle="@string/auto_withdraw_title"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_2xl">

            <!-- Balance Hero -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/balance_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                android:layout_marginTop="@dimen/space_l"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_gradient"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_xl">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/withdraw_lightning_balance_label"
                        android:textAppearance="@style/Text.Caption"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/balance_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="₿0"
                        android:textAppearance="@style/Text.DisplayAmount"
                        android:textColor="@color/color_text_primary"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/fiat_balance_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="16sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Primary Withdraw CTA -->
            <Button
                android:id="@+id/withdraw_button"
                style="@style/Widget.Button.Primary.Green"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                android:layout_marginTop="@dimen/space_l"
                android:text="@string/withdraw_lightning_title"
                android:textAllCaps="false"
                android:textSize="17sp" />

            <!-- Zero-balance hint -->
            <TextView
                android:id="@+id/zero_balance_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_2xl"
                android:layout_marginTop="@dimen/space_s"
                android:gravity="center"
                android:text="@string/manual_withdraw_no_balance"
                android:textAppearance="@style/Text.Helper"
                android:visibility="gone" />

            <!-- Automation Section -->
            <TextView
                style="@style/Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/section_gap"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:text="@string/withdraw_hub_section_automation" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/auto_withdraw_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/color_bg_light"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/margin_screen_horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_withdraw_hero_title"
                                android:textAppearance="@style/Text.RowTitle" />

                            <TextView
                                android:id="@+id/auto_status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_m"
                                android:background="@drawable/bg_pill_badge"
                                android:paddingHorizontal="@dimen/space_m"
                                android:paddingVertical="@dimen/space_xs"
                                android:textAppearance="@style/Text.Badge"
                                android:textColor="@color/color_text_tertiary"
                                tools:text="Active" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/auto_summary_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/Text.RowSubtitle"
                            android:textColor="@color/color_text_secondary"
                            tools:text="To you@wallet.com when balance exceeds 50,000 ₿" />

                    </LinearLayout>

                    <ImageView
                        android:importantForAccessibility="no"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="@dimen/space_m"
                        android:src="@drawable/ic_chevron_forward"
                        app:tint="@color/color_text_tertiary" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Activity Section -->
            <LinearLayout
                android:id="@+id/history_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/margin_screen_horizontal"
                android:paddingTop="@dimen/section_gap"
                android:paddingBottom="@dimen/row_padding_vertical"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text.SectionHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_withdraw_section_history" />

                <TextView
                    android:id="@+id/see_all_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="@dimen/space_s"
                    android:paddingVertical="@dimen/space_xs"
                    android:text="@string/auto_withdraw_see_all"
                    android:textAppearance="@style/Text.SecondaryButton"
                    android:textColor="@color/color_primary"
                    android:visibility="gone" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/history_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_screen_horizontal"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <!-- Empty State -->
                <include
                    android:id="@+id/history_empty_container"
                    layout="@layout/component_empty_state" />

                <!-- History List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/history_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingVertical="@dimen/space_s"
                    android:visibility="gone"
                    tools:listitem="@layout/item_auto_withdraw_history" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
