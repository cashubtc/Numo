<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/numo_navy_light">

    <!-- ======================== -->
    <!-- STEP 1: WELCOME SCREEN   -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/welcome_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:visibility="gone">

        <!-- Background (starts white, transitions to navy via animator) -->
        <View
            android:id="@+id/welcome_background_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white" />

        <!-- Navy curve - hidden in new design, kept for ID compatibility -->
        <ImageView
            android:id="@+id/welcome_navy_curve"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_welcome_curve"
            android:scaleType="fitXY"
            android:visibility="gone"
            android:alpha="0" />

        <!-- Emoji container (BEFORE content so emojis render behind text) -->
        <FrameLayout
            android:id="@+id/emoji_burst_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false" />

        <!-- Content Layer (on top of emojis) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="32dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Numo Wordmark (white vector, tinted navy by animator initially) -->
            <ImageView
                android:id="@+id/welcome_wordmark"
                android:layout_width="200dp"
                android:layout_height="88dp"
                android:src="@drawable/ic_numo_wordmark_white"
                android:contentDescription="@string/app_name"
                android:alpha="0" />

            <!-- Tagline (color set by animator: starts navy, transitions to white) -->
            <TextView
                android:id="@+id/welcome_tagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/onboarding_welcome_tagline"
                android:textSize="17sp"
                android:lineHeight="24sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:alpha="0"
                android:paddingHorizontal="16dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Get Started button (white bg, navy text — visible after color transition) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/accept_button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/onboarding_get_started"
                android:textSize="18sp"
                android:textColor="@color/numo_navy"
                android:textAllCaps="false"
                android:alpha="0"
                android:paddingVertical="4dp"
                app:cornerRadius="32dp"
                app:backgroundTint="#FFFFFF" />

            <!-- Terms Text (below button) -->
            <TextView
                android:id="@+id/terms_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/onboarding_terms_text"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:alpha="0"
                android:gravity="center"
                android:paddingHorizontal="16dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 2: CHOOSE PATH      -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/choose_path_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/numo_navy_light"
        android:visibility="gone">

        <!-- Setup content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_setup_title"
                android:textSize="32sp"
                android:textColor="@color/numo_fluorescent_green"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.05" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

            <!-- Option rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Create New Wallet -->
                <LinearLayout
                    android:id="@+id/create_wallet_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_plus_stroke"
                        android:contentDescription="@string/onboarding_create_wallet_title" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_create_wallet_title"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/onboarding_create_wallet_subtitle"
                            android:textSize="14sp"
                            android:textColor="#73FFFFFF" />

                    </LinearLayout>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="8dp" />

                <!-- Restore from Backup -->
                <LinearLayout
                    android:id="@+id/restore_wallet_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_clock_stroke"
                        android:contentDescription="@string/onboarding_restore_wallet_title" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_restore_wallet_title"
                            android:textSize="16sp"
                            android:textColor="#FFFFFF"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="@string/onboarding_restore_wallet_subtitle"
                            android:textSize="14sp"
                            android:textColor="#73FFFFFF" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Gradient fade into teaser — covers bottom half of screen -->
        <View
            android:id="@+id/teaser_gradient"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_teaser_gradient" />

        <!-- Teaser card -->
        <FrameLayout
            android:id="@+id/teaser_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:paddingHorizontal="16dp"
            android:paddingBottom="34dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_teaser_card"
                android:clipChildren="true"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="26dp"
                    android:paddingHorizontal="24dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/explainer_teaser_title"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="true"
                        android:letterSpacing="-0.03"
                        android:lineSpacingMultiplier="1.05" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/teaser_illustration"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="fitCenter"
                    android:clipToPadding="false"
                    android:contentDescription="@string/explainer_image_placeholder" />

            </LinearLayout>

        </FrameLayout>

        <!-- Explainer overlay -->
        <FrameLayout
            android:id="@+id/explainer_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Backdrop -->
            <View
                android:id="@+id/explainer_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#80000000"
                android:alpha="0" />

            <!-- Sheet -->
            <LinearLayout
                android:id="@+id/explainer_sheet"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/numo_navy"
                android:translationY="2000dp">

                <!-- Close button -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingTop="16dp">

                    <FrameLayout
                        android:id="@+id/explainer_close_btn"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_explainer_close_btn"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_close"
                            android:alpha="0.6"
                            android:contentDescription="@string/navigation_drawer_close" />

                    </FrameLayout>

                </FrameLayout>

                <!-- Slides ViewPager -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/explainer_view_pager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical" />

                <!-- Swipe hint chevrons -->
                <LinearLayout
                    android:id="@+id/chevron_hint_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="16dp"
                    android:paddingBottom="54dp">

                    <ImageView
                        android:id="@+id/chevron_hint_1"
                        android:layout_width="24dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_chevron_down_hint"
                        android:alpha="0.12"
                        android:contentDescription="@null" />

                    <ImageView
                        android:id="@+id/chevron_hint_2"
                        android:layout_width="24dp"
                        android:layout_height="14dp"
                        android:layout_marginTop="-6dp"
                        android:src="@drawable/ic_chevron_down_hint"
                        android:alpha="0.12"
                        android:contentDescription="@null" />

                    <ImageView
                        android:id="@+id/chevron_hint_3"
                        android:layout_width="24dp"
                        android:layout_height="14dp"
                        android:layout_marginTop="-6dp"
                        android:src="@drawable/ic_chevron_down_hint"
                        android:alpha="0.12"
                        android:contentDescription="@null" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 3: ENTER SEED       -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/enter_seed_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Back button -->
            <ImageView
                android:id="@+id/seed_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:src="@drawable/ic_chevron_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#99FFFFFF"
                android:contentDescription="@string/onboarding_seed_toolbar_back" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:text="@string/onboarding_seed_toolbar_title"
                android:textSize="32sp"
                android:textColor="@color/numo_fluorescent_green"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.05" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="24dp">

                    <!-- Instructions -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/onboarding_seed_instruction_title"
                        android:textSize="24sp"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/onboarding_seed_instruction_body"
                        android:textSize="15sp"
                        android:textColor="#99FFFFFF"
                        android:lineHeight="20sp" />

                    <!-- Seed Input Grid -->
                    <androidx.gridlayout.widget.GridLayout
                        android:id="@+id/seed_input_grid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:columnCount="2"
                        app:rowCount="6" />

                    <!-- Paste Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/paste_button"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:text="@string/onboarding_seed_paste_button"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:background="@drawable/bg_button_outlined_dark"
                        app:backgroundTint="@null"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_copy"
                        app:iconSize="18dp"
                        app:iconTint="#FFFFFF"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp" />

                    <!-- Validation Status -->
                    <LinearLayout
                        android:id="@+id/seed_validation_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/seed_validation_icon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_check"
                            app:tint="@color/numo_fluorescent_green" />

                        <TextView
                            android:id="@+id/seed_validation_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/onboarding_seed_validation_ready"
                            android:textSize="14sp"
                            android:textColor="@color/numo_fluorescent_green" />

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <!-- Continue Button - Fixed at bottom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="32dp"
                android:background="@color/numo_navy_light">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/seed_continue_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/onboarding_seed_continue"
                    android:textSize="17sp"
                    android:textColor="@color/button_text_onboarding"
                    android:textAllCaps="false"
                    android:enabled="false"
                    android:alpha="0.5"
                    android:background="@drawable/bg_button_white"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null"
                    app:cornerRadius="28dp"
                    app:elevation="0dp" />

            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 4a: GENERATING      -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/generating_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="48dp">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/numo_fluorescent_green" />

            <TextView
                android:id="@+id/generating_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/onboarding_status_creating_wallet"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/onboarding_generating_hint"
                android:textSize="14sp"
                android:textColor="#99FFFFFF"
                android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 4b: FETCHING BACKUP -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/fetching_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="48dp">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/numo_fluorescent_green" />

            <TextView
                android:id="@+id/fetching_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/onboarding_fetching_searching_backup"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/onboarding_fetching_checking_relays"
                android:textSize="14sp"
                android:textColor="#99FFFFFF"
                android:gravity="center" />

        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 5: REVIEW MINTS     -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/review_mints_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Back button -->
            <ImageView
                android:id="@+id/mints_back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:src="@drawable/ic_chevron_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#99FFFFFF"
                android:contentDescription="@string/onboarding_mints_toolbar_back" />

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="8dp"
                android:text="@string/onboarding_mints_toolbar_title"
                android:textSize="32sp"
                android:textColor="@color/numo_fluorescent_green"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="-0.03"
                android:lineSpacingMultiplier="1.05" />

            <!-- Backup Status Card -->
            <LinearLayout
                android:id="@+id/backup_status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/numo_navy"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/backup_status_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_cloud_done"
                    app:tint="@color/numo_fluorescent_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/backup_status_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/onboarding_backup_found_title"
                        android:textSize="15sp"
                        android:textColor="@color/numo_fluorescent_green"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/backup_status_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/onboarding_backup_found_subtitle"
                        android:textSize="13sp"
                        android:textColor="#99FFFFFF" />

                </LinearLayout>

            </LinearLayout>

            <!-- Mints RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mints_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false" />

            <!-- Fixed Bottom Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp"
                android:background="@color/numo_navy_light">

                <!-- Continue - primary button (matches seed_continue_button style) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mints_continue_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/onboarding_mints_continue_new_wallet"
                    android:textSize="17sp"
                    android:textColor="@color/button_text_onboarding"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_button_white"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null"
                    app:cornerRadius="28dp"
                    app:elevation="0dp" />

            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 6: RESTORING        -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/restoring_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_restoring_title"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />

            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:gravity="center_horizontal">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/numo_fluorescent_green" />

                    <TextView
                        android:id="@+id/restoring_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/onboarding_restoring_initializing"
                        android:textSize="15sp"
                        android:textColor="#99FFFFFF"
                        android:gravity="center" />

                    <!-- Mint Progress Items -->
                    <LinearLayout
                        android:id="@+id/mint_progress_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="32dp" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- ======================== -->
    <!-- STEP 7: SUCCESS          -->
    <!-- ======================== -->
    <FrameLayout
        android:id="@+id/success_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.2" />

            <!-- Success Checkmark -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <ImageView
                    android:id="@+id/success_checkmark"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_success_checkmark"
                    android:contentDescription="@string/payment_received_success_icon_description" />

            </FrameLayout>

            <!-- Success Text -->
            <TextView
                android:id="@+id/success_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/onboarding_success_created_title"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <TextView
                android:id="@+id/success_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/onboarding_success_created_subtitle"
                android:textSize="16sp"
                android:textColor="#99FFFFFF"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.1" />

            <!-- Balance Changes Section (Restore only) -->
            <LinearLayout
                android:id="@+id/success_balance_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboarding_success_balance_by_mint"
                    android:textSize="12sp"
                    android:textColor="#73FFFFFF"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/balance_changes_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.3" />

            <!-- Enter Wallet Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/enter_wallet_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/onboarding_enter_wallet_button"
                android:textSize="17sp"
                android:textColor="@color/button_text_onboarding"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_white"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"
                app:cornerRadius="28dp"
                app:elevation="0dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
